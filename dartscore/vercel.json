{
  "version": 2,
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(?!.*\\.(?:js|css|png|jpg|jpeg|gif|svg|json|ico|woff|woff2|ttf|otf|wasm)$).*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
